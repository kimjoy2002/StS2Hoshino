{
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0r.char": "……我不会再犯那个错误了。",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0r.next": "瞄准",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1r.ancient": "你在说什么？",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.char": "让开。",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.next": "瞄准",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.1-1r.ancient": "你还没玩腻吗？",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0r.char": "不让开的话我就开枪了。",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0r.next": "瞄准",
  "THE_ARCHITECT.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1r.ancient": "你总是不听话呢。",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.ancient": "从没见过的客人啊！对我的藏品感兴趣吗？",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.next": "继续",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.char": "[i][font_size=22]你在藏品中寻找着那个东西。理所当然地，找不到。[/font_size][/i]",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.next": "继续",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.0-2.ancient": "看来你有想找的东西啊！告诉我的话，下次我帮你弄来！",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.ancient": "又来了啊，穿着奇特衣服的小姑娘！快来看看吧！",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.ancient": "又见面了！快来看看吧！",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.next": "继续",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.char": "不知道有没有老师会喜欢的东西呢……",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.next": "继续",
  "DARV.talk.STS2HOSHINO-ST_S2_HOSHINO.2-2.ancient": "如果是送礼的话，我推荐这边的藏品。虽然也有被 [sine]诅咒[/sine] 的东西就是了！！",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.char": "呜嘿~ 太厉害了。是超级大的鲸鱼啊！",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.next": "继续",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.ancient": "[sine]……你是……第一次……见到鲸鱼吗……？[/sine]",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.next": "感叹",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.0-2.char": "它居然会说话！",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.char": "大叔我也上了年纪了吗~",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.next": "继续",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.1-1r.ancient": "[sine]……为了胜利……接受……我的祝福吧……[/sine]",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0r.char": "来看鲸鱼真的很治愈呢~",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0r.next": "继续",
  "NEOW.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1r.ancient": "[sine]……醒来吧……[/sine]",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.ancient": "真是位穿着奇特的客人呢！\n但我这里准备了更美丽的衣服哦！",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.next": "回答",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.char": "大叔我现在身上没钱呢~",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.next": "继续",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.0-2.ancient": "钱没关系。只要你能帮我击败建筑师。",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.ancient": "您又来了啊！为神秘的客人准备了特别的礼物哦。",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.ancient": "快请进。这里到处都是为您准备的特别礼物。",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.next": "回答",
  "NONUPEIPE.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.char": "我的后辈中可是有个超级大富翁哦~",
  "OROBAS.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.ancient": "没见过的人类！头上有光环？！枪！！好奇怪！",
  "OROBAS.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0.ancient": "又见面了！另一个世界？？学园！？多告诉我一些！",
  "OROBAS.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0.next": "继续",
  "OROBAS.talk.STS2HOSHINO-ST_S2_HOSHINO.1-1.char": "大叔我不擅长这种气氛呢~",
  "OROBAS.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0r.ancient": "可怕的枪！！禁止暴力！！快拿走！",
  "PAEL.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.char": "哪里适合午睡呢~",
  "PAEL.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.next": "继续",
  "PAEL.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.ancient": "[thinky_dots]这里是做梦最好的地方……[/thinky_dots]",
  "PAEL.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0.ancient": "[thinky_dots]拿走我的肉吧。\n会对你做个好梦有帮助的……[/thinky_dots]",
  "PAEL.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0.next": "继续",
  "PAEL.talk.STS2HOSHINO-ST_S2_HOSHINO.1-1.char": "呜哇~ 大叔我觉得这个稍微有点恶心呢。",
  "PAEL.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0r.ancient": "[thinky_dots]拥有阴暗过去的少女啊……\n良好的睡眠能让心境平静……[/thinky_dots]",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.char": "盾牌！？那种软弱的装备是赢不了的！！",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.next": "说话",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.char": "对不起啊~ 但这是很重要的东西呢。",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.next": "继续",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.0-2.ancient": "那就拿走更强大的武器作为代替吧！！",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.ancient": "很强大的枪嘛！！但还需要更多！！",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.char": "和我战斗吧，星野！！",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.next": "战斗",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.char": "[i][font_size=22]星野与坦斯进行了对练。[/font_size][/i]",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.next": "继续",
  "TANX.talk.STS2HOSHINO-ST_S2_HOSHINO.2-2.ancient": "动作不错，拿走武器吧！！",
  "TEZCATARA.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.ancient": "这里难得见到 [jitter][b]客人[/b][/jitter] 呢！想要什么吗，孩子？",
  "TEZCATARA.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.ancient": "饿了吗？吃点东西再走吧。我烤了 [jitter][b]曲奇[/b][/jitter] 哦！",
  "TEZCATARA.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.ancient": "你的表情看起来很阴沉呢\n是遇到什么不好的事了吗？",
  "TEZCATARA.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.next": "响应",
  "TEZCATARA.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.char": "只是……想到了某个人。",
  "TEZCATARA.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.next": "继续",
  "TEZCATARA.talk.STS2HOSHINO-ST_S2_HOSHINO.2-2.ancient": "看来你在为过去的事情感到后悔呢，孩子。\n把那些后悔都在这里 [jitter][b]烧掉[/b][/jitter] 吧。",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.ancient": "有个有趣的 [sine]契约[/sine]。要听听看吗？",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.0-0.next": "怀疑",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.char": "以前我也签过这样的契约……",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.0-1.next": "继续",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.0-2.ancient": "害怕契约吗？但在这里你会需要力量的。",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.1-0r.ancient": "看你的眼睛就知道。你需要 [sine]力量[/sine] 对吧？",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.ancient": "寄宿在那个身体里的 [sine]神秘[/sine] 很有趣呢。",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.2-0.next": "回答",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.char": "我见过和你 [jitter]同类[/jitter] 的家伙。",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.2-1.next": "继续",
  "VAKUU.talk.STS2HOSHINO-ST_S2_HOSHINO.2-2.ancient": "啊，那肯定是个公正又英俊的人吧。"
}
